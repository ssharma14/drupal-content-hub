<?php

/**
 * @file
 * Content Hub Styling module.
 */

use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_preprocess_page().
 */
function content_hub_styling_preprocess_page(&$variables) {
  $route = \Drupal::routeMatch()->getRouteName();
  // Attach library on the content hub view page.
  if ($route === 'view.content_hub.page_1') {
    $variables['#attached']['library'][] = 'content_hub_styling/content-hub';
    $variables['attributes']['class'][] = 'content-hub-page';
  }
}

/**
 * Implements hook_preprocess_views_view().
 */
function content_hub_styling_preprocess_views_view(&$variables) {
  $view = $variables['view'];
  if ($view->id() === 'content_hub') {
    $variables['attributes']['class'][] = 'content-hub-view';
  }
}

/**
 * Implements hook_form_alter().
 */
function content_hub_styling_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  if ($form_id === 'views_exposed_form' && isset($form['#id']) && str_contains($form['#id'], 'content-hub')) {
    $form['#attributes']['class'][] = 'content-hub-search-form';
  }
}

/**
 * Implements hook_theme_registry_alter().
 */
function content_hub_styling_theme_registry_alter(&$theme_registry) {
  $path = \Drupal::service('extension.list.module')->getPath('content_hub_styling') . '/templates';
  if (isset($theme_registry['field__node__field_tags'])) {
    $theme_registry['field__node__field_tags']['path'] = $path;
  }
}

/**
 * Implements hook_preprocess_block().
 */
function content_hub_styling_preprocess_block(&$variables) {
  if (isset($variables['plugin_id']) && str_starts_with($variables['plugin_id'], 'facet_block:')) {
    $variables['attributes']['class'][] = 'content-hub-facet';
  }
}
